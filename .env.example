# Agentic Chat local development environment
#
# Copy this file to `.env` for local dogfood/live-provider runs. `.env` is
# intentionally ignored by git. Do not commit bearer tokens or private paths.
# Load it in a POSIX shell with:
#
#   set -a
#   . ./.env
#   set +a

# Deterministic dogfood e2e
# These are optional; `npm run test:e2e:dogfood` generates defaults under
# logs/dogfood-runs/<run-id>/ when they are omitted.
DOGFOOD_TIMEOUT_MS=300000
DOGFOOD_TURN_TIMEOUT_MS=120000

# Optional live model dogfood
# Enable only when you intentionally want to spend live model tokens.
AGENTIC_CHAT_LIVE_DOGFOOD=false
AGENTIC_CHAT_LIVE_BASE_URL=https://llm.example/api
AGENTIC_CHAT_LIVE_MODEL=model-id
AGENTIC_CHAT_LIVE_API_KEY_FILE=/tmp/agentic-chat-live.key
AGENTIC_CHAT_LIVE_EXTERNAL_ROOT=/path/to/workspace
AGENTIC_CHAT_LIVE_VAULT=/path/to/obsidian-vault

# Optional live dogfood repo profile targets.
# Accepts either an array of repo paths or objects with repoPath/notePath/label.
# DOGFOOD_REPO_TARGETS_JSON='["repos/service-a","repos/service-b"]'

# Optional proxy for live provider calls. Keep localhost out of the proxy so
# WDIO/chromedriver control traffic stays local.
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1,::1

# Backwards-compatible OpenWebUI live e2e variables. Prefer the
# AGENTIC_CHAT_LIVE_* names for dogfood.
OPENWEBUI_BASE_URL=
OPENWEBUI_MODEL=
OPENWEBUI_API_KEY_FILE=

# Optional LLM-as-judge evals. These are separate from plugin runtime settings
# and are only used by `npm run eval:agentic:judge`.
AGENTIC_EVAL_JUDGE_BASE_URL=https://llm.example/api
AGENTIC_EVAL_JUDGE_MODEL=judge-model-id
AGENTIC_EVAL_JUDGE_API_KEY_FILE=/tmp/agentic-chat-judge.key
AGENTIC_EVAL_JUDGE_API_KEY=
AGENTIC_EVAL_JUDGE_HTTPS_PROXY=
AGENTIC_EVAL_JUDGE_HTTP_PROXY=
AGENTIC_EVAL_JUDGE_TIMEOUT_MS=120000
AGENTIC_EVAL_JUDGE_MAX_TOKENS=1200
