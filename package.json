{
  "name": "obsidian-agentic-chat",
  "version": "0.27.1",
  "description": "Agent-led AI chat in the Obsidian right sidebar, powered by OpenRouter, Ollama, or OpenAI-compatible gateways.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "install:local": "tsx scripts/install-local.ts",
    "install:android": "node scripts/install-android-plugin.mjs",
    "dev:vault": "tsx scripts/install-local.ts --watch",
    "dogfood": "tsx scripts/dogfood.ts",
    "dogfood:generate-vault": "tsx scripts/generate-dogfood-vault.ts",
    "dogfood:assert": "tsx scripts/assert-dogfood-invariants.ts",
    "dogfood:report": "tsx scripts/report-dogfood-run.ts",
    "test:e2e:dogfood": "node --import tsx scripts/run-dogfood-e2e.ts",
    "eval:agentic": "node --import tsx scripts/run-agentic-evals.ts",
    "eval:agentic:dogfood": "node --import tsx scripts/run-agentic-evals.ts --run-scripted",
    "eval:agentic:judge": "node --import tsx scripts/run-agentic-evals.ts --suite test/evals/agentic-chat/judge.eval.json --run-judge",
    "eval:agentic:compare": "node --import tsx scripts/compare-agentic-evals.ts",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "build": "tsc -noEmit && node esbuild.config.mjs production && node scripts/verify-release.mjs && node scripts/verify-mobile-compat.mjs",
    "build:e2e": "node scripts/build-e2e.mjs",
    "typecheck": "tsc -noEmit",
    "typecheck:e2e": "tsc -p tsconfig.e2e.json --noEmit",
    "lint": "eslint .",
    "lint:obsidian": "eslint -c eslint.config.obsidian.mjs src",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:live": "vitest run --config vitest.live.config.ts",
    "eval:provider-cache-live": "node scripts/eval-provider-cache-live.mjs",
    "verify:provider-live": "node scripts/verify-provider-live.mjs",
    "analyze:session": "node scripts/analyze-session-trace.mjs",
    "verify:fast": "node scripts/verify-fast.mjs",
    "pretest:e2e": "npm run build:e2e",
    "test:e2e": "node --import tsx scripts/run-e2e.ts",
    "pretest:e2e:mobile": "npm run build:e2e",
    "test:e2e:mobile": "node scripts/run-e2e-mobile.mjs",
    "test:e2e:matrix": "node scripts/run-e2e-matrix.mjs",
    "verify:mobile": "node scripts/verify-mobile-compat.mjs",
    "check:remote-mcp": "node --import tsx scripts/check-remote-mcp.ts"
  },
  "keywords": [
    "obsidian",
    "obsidian-plugin",
    "ai",
    "agent",
    "openrouter",
    "chat"
  ],
  "author": "tardigrde",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.14.0",
    "@wdio/cli": "^9.29.1",
    "@wdio/globals": "^9.29.1",
    "@wdio/local-runner": "^9.29.1",
    "@wdio/mocha-framework": "^9.29.1",
    "@wdio/spec-reporter": "^9.29.1",
    "esbuild": "^0.28.1",
    "eslint": "^10.7.0",
    "eslint-plugin-no-unsanitized": "^4.1.5",
    "eslint-plugin-obsidianmd": "^0.4.1",
    "globals": "^17.7.0",
    "jiti": "^2.7.0",
    "mocha": "^10.8.2",
    "obsidian": "^1.7.2",
    "obsidian-launcher": "^3.1.1",
    "tsx": "^4.22.4",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.61.1",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.9",
    "wdio-obsidian-reporter": "^3.1.1",
    "wdio-obsidian-service": "^3.1.1"
  },
  "dependencies": {
    "@earendil-works/pi-agent-core": "0.79.1",
    "@earendil-works/pi-ai": "0.79.1",
    "typebox": "1.1.38"
  },
  "overrides": {
    "@electron/get": {
      "undici": "7.28.0"
    },
    "cheerio": {
      "undici": "7.28.0"
    },
    "mocha": {
      "serialize-javascript": "7.0.5"
    },
    "vitepress": {
      "vite": "6.4.3"
    },
    "webdriverio": {
      "undici": "7.28.0"
    }
  }
}
