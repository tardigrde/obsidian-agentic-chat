{
  "name": "obsidian-agentic-chat",
  "version": "0.1.0",
  "description": "Agent-led AI chat in the Obsidian right sidebar, powered by OpenRouter with privacy-preserving provider routing.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit && node esbuild.config.mjs production",
    "typecheck": "tsc -noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:live": "vitest run --config vitest.live.config.ts"
  },
  "keywords": [
    "obsidian",
    "obsidian-plugin",
    "ai",
    "agent",
    "openrouter",
    "chat"
  ],
  "author": "tardigrde",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.14.0",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.21.5",
    "obsidian": "^1.7.2",
    "typescript": "^5.5.4",
    "vitest": "^2.1.9"
  },
  "dependencies": {
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.23.5"
  }
}
