{
  "name": "obsidian-agentic-chat",
  "version": "0.21.0",
  "description": "Agent-led AI chat in the Obsidian right sidebar, powered by OpenRouter with privacy-preserving provider routing.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit && node esbuild.config.mjs production && node scripts/verify-release.mjs",
    "typecheck": "tsc -noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:live": "vitest run --config vitest.live.config.ts",
    "pretest:e2e": "npm run build",
    "test:e2e": "wdio run ./wdio.conf.mts"
  },
  "keywords": [
    "obsidian",
    "obsidian-plugin",
    "ai",
    "agent",
    "openrouter",
    "chat"
  ],
  "author": "tardigrde",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.14.0",
    "@wdio/cli": "^9.28.0",
    "@wdio/globals": "^9.28.0",
    "@wdio/local-runner": "^9.28.0",
    "@wdio/mocha-framework": "^9.28.0",
    "@wdio/spec-reporter": "^9.28.0",
    "esbuild": "^0.21.5",
    "eslint": "^9.39.4",
    "globals": "^17.6.0",
    "jiti": "^2.7.0",
    "mocha": "^10.8.2",
    "obsidian": "^1.7.2",
    "obsidian-launcher": "^3.1.1",
    "semantic-release": "^25.0.5",
    "tsx": "^4.22.4",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.61.1",
    "vitest": "^2.1.9",
    "wdio-obsidian-reporter": "^3.1.1",
    "wdio-obsidian-service": "^3.1.1"
  },
  "dependencies": {
    "@earendil-works/pi-agent-core": "0.79.1",
    "@earendil-works/pi-ai": "0.79.1",
    "typebox": "1.1.38"
  }
}
